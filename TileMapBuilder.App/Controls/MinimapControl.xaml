<UserControl x:Class="TileMapBuilder.App.Controls.MinimapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TileMapBuilder.App.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="{StaticResource Brush_Background_Dark}"
            BorderBrush="{StaticResource Brush_Border_Normal}"
            BorderThickness="2"
            CornerRadius="4">
        <Grid>
            <!-- Minimap Canvas -->
            <Canvas x:Name="MinimapCanvas" ClipToBounds="True"/>

            <!-- Viewport indicator -->
            <Rectangle x:Name="ViewportRect"
                       Stroke="{StaticResource Brush_Accent_Primary}"
                       StrokeThickness="2"
                       Fill="Transparent"
                       IsHitTestVisible="False"/>

            <!-- Label -->
            <TextBlock Text="Minimap" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Top"
                       Margin="0,5"
                       FontSize="10"
                       Foreground="{StaticResource Brush_Text_Hint}"/>
        </Grid>
    </Border>
</UserControl>
