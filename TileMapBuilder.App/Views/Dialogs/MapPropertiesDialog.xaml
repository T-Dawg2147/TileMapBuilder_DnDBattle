<Window x:Class="TileMapBuilder.App.Views.Dialogs.MapPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Map Properties"
        Width="420" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush_Background_Control}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="⚙️ Map Properties" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Map Name:" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding MapName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Text="Description:" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                         AcceptsReturn="True" TextWrapping="Wrap" Height="60" Margin="0,0,0,8"/>

                <TextBlock Text="Author:" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Text="Environment Type:" FontSize="11" Margin="0,0,0,2"/>
                <ComboBox ItemsSource="{Binding EnvironmentTypes}" 
                          SelectedItem="{Binding EnvironmentType}" Margin="0,0,0,8"/>

                <Separator Margin="0,4,0,8"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                        <TextBlock Text="Width:" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding Width}" IsReadOnly="True" 
                                 Background="{StaticResource Brush_Background_Darkest}"
                                 ToolTip="Use Map Resize to change dimensions"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                        <TextBlock Text="Height:" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding Height}" IsReadOnly="True"
                                 Background="{StaticResource Brush_Background_Darkest}"
                                 ToolTip="Use Map Resize to change dimensions"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,8">
                        <TextBlock Text="Cell Size (px):" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding CellSize}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                        <TextBlock Text="Feet Per Square:" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding FeetPerSquare}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Background Color:" FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Command="{Binding CancelCommand}" IsCancel="True"/>
            <Button Content="Apply" Width="80" Command="{Binding ConfirmCommand}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
