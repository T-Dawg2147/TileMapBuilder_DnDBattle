<Window x:Class="TileMapBuilder.App.Views.Dialogs.ImportTileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Import Tiles"
        SizeToContent="Height"
        Width="420"
        Background="{StaticResource Brush_Background_Darkest}"
        Foreground="{StaticResource Brush_Text_Primary}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Files -->
            <RowDefinition Height="Auto" />
            <!-- Category -->
            <RowDefinition Height="Auto" />
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ── Files ──────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Image File(s)" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{StaticResource Brush_Text_Primary}" />
            <DockPanel>
                <Button Content="Browse…"
                        DockPanel.Dock="Right"
                        Command="{Binding BrowseFilesCommand}"
                        Padding="8,4"
                        Margin="8,0,0,0" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{StaticResource Brush_Text_Secondary}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FileCount}" Value="0">
                                    <Setter Property="Text" Value="No files selected" />
                                    <Setter Property="Foreground" Value="{StaticResource Brush_Text_Hint}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="{Binding FileCount, StringFormat='{}{0} file(s) selected'}" />
                </TextBlock>
            </DockPanel>
        </StackPanel>

        <!-- ── Category ──────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Category" FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{StaticResource Brush_Text_Primary}" />
            <ComboBox ItemsSource="{Binding AvailableCategories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Padding="4" />
        </StackPanel>

        <!-- ── Buttons ───────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Import"
                    Command="{Binding ConfirmCommand}"
                    IsDefault="True"
                    Width="80" Padding="4,6"
                    Margin="0,0,8,0" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Width="80" Padding="4,6" />
        </StackPanel>
    </Grid>
</Window>
