<UserControl x:Class="TileMapBuilder.App.Views.TileMapEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TileMapBuilder.App.Controls"
        Background="{StaticResource Brush_Background_Darkest}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ TOP MENU BAR ═══════════ -->
        <Menu Grid.Row="0" Background="{StaticResource Brush_Background_Control}">
            <MenuItem Header="File" Foreground="{StaticResource Brush_Text_Primary}">
                <MenuItem Header="New Map..." Command="{Binding CreateNewMapCommand}"/>
                <MenuItem Header="Open Map..." Command="{Binding LoadMapCommand}"/>
                <MenuItem Header="Save Map" Command="{Binding SaveMapCommand}"/>
                <MenuItem Header="Save Map As..." Command="{Binding SaveMapAsCommand}"/>
                <Separator/>
                <MenuItem Header="Export as Image..." Command="{Binding ExportAsImageCommand}"/>
            </MenuItem>
            <MenuItem Header="Edit" Foreground="{StaticResource Brush_Text_Primary}">
                <!-- These bind to TileMapControlViewModel via the MapControl's DataContext -->
                <MenuItem Header="Undo" 
                          Command="{Binding DataContext.UndoCommand, ElementName=MapEditorControl}"
                          InputGestureText="Ctrl+Z"/>
                <MenuItem Header="Redo" 
                          Command="{Binding DataContext.RedoCommand, ElementName=MapEditorControl}"
                          InputGestureText="Ctrl+Y"/>
            </MenuItem>
            <MenuItem Header="View" Foreground="{StaticResource Brush_Text_Primary}">
                <MenuItem Header="Toggle DM View" 
                          Command="{Binding DataContext.ToggleDMViewCommand, ElementName=MapEditorControl}"/>
                <MenuItem Header="Toggle Fog of War" 
                          Command="{Binding DataContext.ToggleFogOfWarCommand, ElementName=MapEditorControl}"/>
            </MenuItem>
        </Menu>

        <!-- ═══════════ MAIN CONTENT ═══════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="200" MaxWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Tile Palette -->
            <!-- DataContext will be set in code-behind to TilePaletteViewModel -->
            <controls:TilePalettePanel x:Name="PalettePanel" Grid.Column="0"/>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3"
                          Background="{StaticResource Brush_Border_Normal}"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Center"/>

            <!-- RIGHT PANEL: Map Canvas + Toolbar -->
            <!-- DataContext will be set in code-behind to TileMapControlViewModel -->
            <controls:TileMapToolbarControl x:Name="MapEditorControl" Grid.Column="2"/>
        </Grid>

        <!-- ═══════════ STATUS BAR ═══════════ -->
        <Border Grid.Row="2" Background="{StaticResource Brush_Background_Control}" 
                Padding="10,4">
            <TextBlock Text="{Binding DataContext.StatusText, ElementName=MapEditorControl, 
                             FallbackValue='Ready'}"
                       Style="{StaticResource HintText}" FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
