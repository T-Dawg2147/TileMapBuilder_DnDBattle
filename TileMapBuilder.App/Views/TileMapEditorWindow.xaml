<UserControl x:Class="TileMapBuilder.App.Views.TileMapEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TileMapBuilder.App.Controls"
        Background="{StaticResource Brush_Background_Darkest}"
        Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ TOP MENU BAR ═══════════ -->
        <Menu Grid.Row="0" Background="{StaticResource Brush_Background_Control}">
            <MenuItem Header="File" Foreground="{StaticResource Brush_Text_Primary}">
                <MenuItem Header="New Map..." Command="{Binding CreateNewMapCommand}"/>
                <MenuItem Header="Open Map..." Command="{Binding LoadMapCommand}"/>
                <MenuItem Header="Save Map" Command="{Binding SaveMapCommand}"/>
                <MenuItem Header="Save Map As..." Command="{Binding SaveMapAsCommand}"/>
                <Separator/>
                <MenuItem Header="Export as Image..." Command="{Binding ExportAsImageCommand}"/>
            </MenuItem>
            <MenuItem Header="Edit" Foreground="{StaticResource Brush_Text_Primary}">
                <MenuItem Header="Undo" InputGestureText="Ctrl+Z" 
                          Command="{Binding ElementName=MapEditorControl, Path=DataContext.UndoCommand}"/>
                <MenuItem Header="Redo" InputGestureText="Ctrl+Y" 
                          Command="{Binding ElementName=MapEditorControl, Path=DataContext.RedoCommand}"/>
            </MenuItem>
            <MenuItem Header="View" Foreground="{StaticResource Brush_Text_Primary}">
                <MenuItem Header="Toggle Grid" Command="{Binding ToggleGridCommand}"/>
                <MenuItem Header="Toggle DM View" 
                          Command="{Binding ElementName=MapEditorControl, Path=DataContext.ToggleDMViewCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ═══════════ MAIN CONTENT AREA ═══════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Tile Palette -->
            <controls:TilePalettePanel x:Name="PalettePanel" Grid.Column="0"/>

            <!-- Center: Map Canvas -->
            <controls:TileMapToolbarControl x:Name="MapEditorControl" Grid.Column="1"/>

            <!-- Right: Tile Editor Panel (shown when editing a tile) -->
            <controls:TileEditorPanel x:Name="TileEditorControl" Grid.Column="2"/>
        </Grid>

        <!-- ═══════════ STATUS BAR ═══════════ -->
        <Border Grid.Row="2" Background="{StaticResource Brush_Background_Control}" Padding="8,4">
            <TextBlock x:Name="StatusBarText" Text="{Binding ElementName=MapEditorControl, Path=DataContext.StatusText}" 
                       Foreground="{StaticResource Brush_Text_Secondary}" FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
