<Window x:Class="TileMapBuilder.App.Views.TileMapEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TileMapBuilder.App.Controls"
        xmlns:views="clr-namespace:TileMapBuilder.App.Views"
        Title="Tile Map Builder" Height="700" Width="1200">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Palette -->
        <controls:TilePalettePanel x:Name="PalettePanel" Grid.Column="0" 
                                TileSelected="PalettePanel_TileSelected"/>

        <!-- Right: Editor -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Menu -->
            <Menu Grid.Row="0" Background="{StaticResource Brush_Background_Control}">
                <MenuItem Header="File" Foreground="{StaticResource Brush_Text_Primary}">
                    <MenuItem Header="New Map..." Click="NewMap_Click"/>
                    <MenuItem Header="Open Map..." Click="OpenMap_Click"/>
                    <MenuItem Header="Save Map" Click="SaveMap_Click"/>
                    <MenuItem Header="Save Map As..." Click="SaveMapAs_Click"/>
                    <Separator/>
                    <MenuItem Header="Export as Image..." Click="ExportImage_Click"/>
                    <Separator/>
                    <MenuItem Header="Close" Click="Close_Click"/>
                </MenuItem>
                <MenuItem Header="Edit" Foreground="{StaticResource Brush_Text_Primary}">
                    <MenuItem Header="Clear All Tiles" Click="ClearAllTiles_Click"/>
                    <MenuItem Header="Resize Map..." Click="ResizeMap_Click"/>
                </MenuItem>
                <MenuItem Header="View" Foreground="{StaticResource Brush_Text_Primary}">
                    <MenuItem Header="Toggle Grid" Click="ToggleGrid_Click" 
                              IsCheckable="True" IsChecked="True" x:Name="MenuShowGrid"/>
                    <MenuItem Header="Zoom In" Click="ZoomIn_Click"/>
                    <MenuItem Header="Zoom Out" Click="ZoomOut_Click"/>
                    <MenuItem Header="Reset View" Click="ResetView_Click"/>
                </MenuItem>
                <MenuItem Header="Map Features" Foreground="{StaticResource Brush_Text_Primary}">
                    <MenuItem Header="Grid Type">
                        <MenuItem Header="Square Grid" Click="SetSquareGrid_Click" IsCheckable="True" IsChecked="True" x:Name="MenuSquareGrid"/>
                        <MenuItem Header="Hex Grid (Flat Top)" Click="SetHexFlatTop_Click" IsCheckable="True" x:Name="MenuHexFlatTop"/>
                        <MenuItem Header="Hex Grid (Pointy Top)" Click="SetHexPointyTop_Click" IsCheckable="True" x:Name="MenuHexPointyTop"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Toggle Gridless Mode" Click="ToggleGridless_Click" IsCheckable="True" x:Name="MenuGridless"/>
                    <Separator/>
                    <MenuItem Header="Custom Grid Size...">
                        <MenuItem Header="5 ft/square (Standard)" Click="SetGridScale_Click" Tag="5"/>
                        <MenuItem Header="10 ft/square" Click="SetGridScale_Click" Tag="10"/>
                        <MenuItem Header="20 ft/square" Click="SetGridScale_Click" Tag="20"/>
                        <MenuItem Header="50 ft/square" Click="SetGridScale_Click" Tag="50"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Add Map Note..." Click="AddMapNote_Click"/>
                    <MenuItem Header="Add Background Layer..." Click="AddBackgroundLayer_Click"/>
                </MenuItem>
            </Menu>

            <!-- Editor Control -->
            <Grid Grid.Row="1">
                <!-- NOTE I would REALLY like to seperate the canvas entity from the tool bar, maybe have the toolbar floating? -->
                <controls:TileMapToolbarControl x:Name="EditorControl"/>

                <controls:MinimapControl x:Name="Minimap" 
                              HorizontalAlignment="Right" 
                              VerticalAlignment="Bottom"
                              Margin="20"
                              Width="200" Height="200"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
